generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonType {
  ARTICLE
  VIDEO
  SANDBOX
  QUIZ
  INTERACTIVE
  MEDIA
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ContentNodeType {
  COURSE
  MODULE
  LESSON
  PAGE
}

enum RelationType {
  PREREQUISITE
  RECOMMENDED
  RELATED
  UNLOCKS
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

// ─── Auth (NextAuth) ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Users ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  avatarUrl     String?   @map("avatar_url")
  role          UserRole  @default(STUDENT)

  // Gamification
  xp             Int      @default(0)
  level          Int      @default(1)
  streakDays     Int      @default(0) @map("streak_days")
  streakLastDate DateTime? @map("streak_last_date")

  preferences Json? @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  accounts        Account[]
  sessions        Session[]
  enrollments     Enrollment[]
  progress        UserProgress[]
  payments        Payment[]
  comments        Comment[]
  achievements    UserAchievement[]
  aiInteractions  AiInteraction[]

  @@map("users")
}

// ─── Courses ──────────────────────────────────────────────────

model Course {
  id             String           @id @default(cuid())
  slug           String           @unique
  title          String
  description    String?          @db.Text
  coverImageUrl  String?          @map("cover_image_url")
  priceRub       Int              @default(0) @map("price_rub")
  status         CourseStatus     @default(DRAFT)
  difficulty     CourseDifficulty @default(BEGINNER)
  estimatedHours Decimal?         @map("estimated_hours") @db.Decimal(4, 1)
  metadata       Json?            @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  modules     Module[]
  enrollments Enrollment[]

  @@map("courses")
}

// ─── Modules ──────────────────────────────────────────────────

model Module {
  id              String @id @default(cuid())
  courseId         String @map("course_id")
  title           String
  orderIndex      Int    @default(0) @map("order_index")
  unlockCondition Json?  @map("unlock_condition")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("modules")
}

// ─── Lessons ──────────────────────────────────────────────────

model Lesson {
  id               String     @id @default(cuid())
  moduleId         String     @map("module_id")
  type             LessonType @default(ARTICLE)
  title            String
  content          Json?      @default("{}")
  orderIndex       Int        @default(0) @map("order_index")
  xpReward         Int        @default(10) @map("xp_reward")
  estimatedMinutes Int?       @map("estimated_minutes")
  isFreePreview    Boolean    @default(false) @map("is_free_preview")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  module         Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress       UserProgress[]
  comments       Comment[]
  aiInteractions AiInteraction[]

  @@index([moduleId])
  @@map("lessons")
}

// ─── Content Graph ────────────────────────────────────────────

model ContentGraph {
  id           String          @id @default(cuid())
  sourceType   ContentNodeType @map("source_type")
  sourceId     String          @map("source_id")
  targetType   ContentNodeType @map("target_type")
  targetId     String          @map("target_id")
  relationType RelationType    @map("relation_type")
  metadata     Json?           @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId])
  @@index([targetId])
  @@map("content_graph")
}

// ─── User Progress ────────────────────────────────────────────

model UserProgress {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  lessonId    String         @map("lesson_id")
  status      ProgressStatus @default(NOT_STARTED)
  score       Int?
  attempts    Int            @default(0)
  answersData Json?          @map("answers_data")
  xpEarned    Int            @default(0) @map("xp_earned")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("user_progress")
}

// ─── Enrollments ──────────────────────────────────────────────

model Enrollment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  courseId    String   @map("course_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  paymentId  String?  @map("payment_id")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

// ─── Payments ─────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  transactionId String?       @unique @map("transaction_id")
  amount        Int
  currency      String        @default("RUB")
  status        PaymentStatus @default(PENDING)
  metadata      Json?         @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@index([userId])
  @@map("payments")
}

// ─── Achievements ─────────────────────────────────────────────

model Achievement {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String? @db.Text
  iconUrl     String? @map("icon_url")
  condition   Json
  xpBonus     Int     @default(0) @map("xp_bonus")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ─── Comments ─────────────────────────────────────────────────

model Comment {
  id       String  @id @default(cuid())
  userId   String  @map("user_id")
  lessonId String  @map("lesson_id")
  parentId String? @map("parent_id")
  content  String  @db.Text
  likes    Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([lessonId])
  @@index([parentId])
  @@map("comments")
}

// ─── Pages ────────────────────────────────────────────────────

model Page {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  blocks      Json?      @default("[]")
  status      PageStatus @default(DRAFT)
  seoTitle    String?    @map("seo_title")
  seoDesc     String?    @map("seo_desc") @db.Text
  ogImageUrl  String?    @map("og_image_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

// ─── AI Interactions ──────────────────────────────────────────

model AiInteraction {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  lessonId     String? @map("lesson_id")
  model        String
  tokensInput  Int     @default(0) @map("tokens_input")
  tokensOutput Int     @default(0) @map("tokens_output")
  costUsd      Decimal @default(0) @map("cost_usd") @db.Decimal(10, 6)
  requestType  String  @map("request_type")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([lessonId])
  @@index([createdAt])
  @@map("ai_interactions")
}
